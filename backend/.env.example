# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/earnhub

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRE=7d

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=0x4AAAAAADPvFLsr1t3Mg-XhatCikKlQGoE
# Allow local development on localhost even when Turnstile is misconfigured.
# Set to false in staging/production environments.
TURNSTILE_BYPASS_LOCALHOST=true

# Paystack (primary payment provider)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Jenga API (East Africa layer)
JENGA_API_KEY=
JENGA_API_SECRET=
JENGA_MERCHANT_CODE=
JENGA_WEBHOOK_URL=
JENGA_COLLECTION_URL=
JENGA_MOBILE_WITHDRAWAL_URL=
JENGA_TOKEN_URL=
JENGA_SOURCE_ACCOUNT_NUMBER=
JENGA_SOURCE_ACCOUNT_NAME=

# Optional transfer recipient bank codes for Friday payouts.
# Fetch valid codes with Paystack's List Banks endpoint for your live markets.
PAYSTACK_TRANSFER_BANK_CODE_KE=
PAYSTACK_TRANSFER_BANK_CODE_GH=

# M-Pesa Daraja (optional Kenya direct collection / withdrawal)
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_TILL=
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline
DARAJA_PASSKEY=
DARAJA_SECURITY_CREDENTIAL=
DARAJA_INITIATOR_NAME=CashFlawHubs
USE_DARAJA=true
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_TILL=
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback

# MTN MoMo (Uganda specialized wallet)
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_COLLECTION_URL=
MTN_MOMO_BASE_URL=
MTN_MOMO_TARGET_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=UGX

# Telebirr (Ethiopia specialized wallet)
TELEBIRR_APP_ID=
TELEBIRR_APP_KEY=
TELEBIRR_MERCHANT_ID=
TELEBIRR_NOTIFY_URL=
TELEBIRR_BASE_URL=

# Tanzania wallet operators
TANZANIA_WALLET_DEPOSIT_URL=
TANZANIA_WALLET_WITHDRAWAL_URL=
TANZANIA_WALLET_API_KEY=
TANZANIA_WALLET_API_SECRET=
TANZANIA_WALLET_PROVIDER=

# Twilio (OTP SMS)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1234567890

# Africa's Talking (optional regional SMS provider - preferred for many African markets)
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
# Optional sender ID configured in Africa's Talking dashboard (alphanumeric or short code)
AFRICASTALKING_SENDER=CashFlaw

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Email (SendGrid)
SENDGRID_API_KEY=SG_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=support@yourdomain.com
SENDGRID_FROM_NAME=Your Company Name
SENDGRID_ENABLE_IN_DEV=false

# Cloudflare R2 (S3-compatible storage)
R2_BUCKET_NAME=your_bucket_name
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_S3_API_URL=https://<accountid>.r2.cloudflarestorage.com/<bucket>
R2_PUBLIC_URL=https://<public-id>.r2.dev

# S3-compatible aliases (for libraries expecting AWS names)
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Survey APIs
CPX_RESEARCH_APP_ID=your_app_id
CPX_RESEARCH_HASH_KEY=your_hash_key
BITLABS_API_TOKEN=your_bitlabs_token

# Microtask APIs
MICROWORKERS_API_KEY=your_microworkers_key
TOLOKA_API_TOKEN=your_toloka_token

# Jobs APIs
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs
JOBICY_API_URL=https://jobicy.com/api/v2/remote-jobs
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_key
JOOBLE_API_KEY=
JOOBLE_API_URL=https://jooble.org/api
JOOBLE_COUNTRY=ke
JOOBLE_KEYWORDS=remote
JOOBLE_LOCATION=
JOBS_SYNC_LIMIT=80

# Offerwall
AYETSTUDIOS_PUB_ID=your_pub_id
AYETSTUDIOS_API_KEY=your_api_key
ADGATE_PUBLISHER_ID=your_publisher_id

# Exchange Rate
EXCHANGE_RATE_API_KEY=your_key

# RabbitMQ
RABBITMQ_URL=amqp://localhost

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Platform Settings
ACTIVATION_FEE_KES=500
PLATFORM_SHARE_KES=300
REFERRAL_REWARD_KES=200
MIN_WITHDRAWAL_KES=200

# Temporary activation bypass for testing (all users treated as activated while window is active)
ACTIVATION_TEST_MODE=false
ACTIVATION_TEST_START_AT=2026-05-04T00:00:00Z
ACTIVATION_TEST_DAYS=15
