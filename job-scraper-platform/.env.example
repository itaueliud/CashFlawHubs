# Core
NODE_ENV=production
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/job-scraper

# Redis
REDIS_URL=redis://redis:6379

# Queue
QUEUE_PREFIX=remotejobs
QUEUE_SCRAPE_CONCURRENCY=20
QUEUE_ENRICH_CONCURRENCY=30
QUEUE_PUBLISH_CONCURRENCY=20

# Scraping
SCRAPER_GLOBAL_RPS=4
SCRAPER_REQUEST_TIMEOUT_MS=30000
SCRAPER_RETRY_ATTEMPTS=6
SCRAPER_MIN_DELAY_MS=500
SCRAPER_MAX_DELAY_MS=2500
SCRAPER_USE_PROXIES=false
SCRAPER_PROXY_LIST=
SCRAPER_RESPECT_ROBOTS=true

# API
API_PORT=8080
WEBSITE_API_BASE_URL=https://your-site.example.com/api
WEBSITE_API_KEY=replace_me

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ENRICHMENT_CACHE_TTL_SECONDS=2592000
ENRICHMENT_BREAKER_TIMEOUT_MS=12000
ENRICHMENT_BREAKER_ERROR_THRESHOLD=50
ENRICHMENT_BREAKER_RESET_MS=30000

# Discovery
DISCOVERY_SEED_DOMAINS=example.com,another-company.com
DISCOVERY_MAX_SITEMAP_URLS=5000
DISCOVERY_CONCURRENCY=8

# Observability
OTEL_SERVICE_NAME=remote-job-scraper
OTEL_EXPORTER_OTLP_ENDPOINT=
