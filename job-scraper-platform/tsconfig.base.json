{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@platform/core": ["packages/core"],
      "@platform/db": ["packages/db"],
      "@platform/enrichment": ["packages/enrichment"],
      "@platform/queue": ["packages/queue"],
      "@platform/scrapers": ["packages/scrapers"]
    },
    "types": ["node"],
    "typeRoots": ["./types", "./node_modules/@types"],
    "ignoreDeprecations": "6.0"
  }
}
