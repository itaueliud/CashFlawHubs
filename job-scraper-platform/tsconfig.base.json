{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@platform/core": ["./packages/core/src/index.ts"],
      "@platform/db": ["./packages/db/src/index.ts"],
      "@platform/enrichment": ["./packages/enrichment/src/index.ts"],
      "@platform/scrapers": ["./packages/scrapers/src/index.ts"]
    },
    "types": ["node", "opossum"],
    "typeRoots": ["./types", "./node_modules/@types"]
  }
}
