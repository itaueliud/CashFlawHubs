{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["node"],
    "typeRoots": ["./types", "./node_modules/@types"],
    "ignoreDeprecations": "6.0"
  }
}
